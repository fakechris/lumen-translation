{
  "identifier": "app.lumen.translate",
  "name": "Lumen",
  "icon": "icon.png",
  "entitlements": ["network"],
  "popclipVersion": 4158,
  "actions": [
    {
      "identifier": "lumen-translate",
      "title": "Lumen",
      "applescript file": "Lumen.applescript",
      "requirements": ["text"],
      "after": "ignore"
    }
  ],
  "options": [
    {
      "identifier": "targetLang",
      "label": "目标语言 Target Language",
      "type": "multiple",
      "default": "zh-CN",
      "values": ["zh-CN", "zh-TW", "en", "ja", "ko", "fr", "de", "es", "ru", "ar", "it", "pt", "th", "vi", "id", "hi", "tr", "nl", "pl"],
      "valueLabels": [
        "中文（简体）",
        "中文（繁體）",
        "English",
        "日本語",
        "한국어",
        "Français",
        "Deutsch",
        "Español",
        "Русский",
        "العربية",
        "Italiano",
        "Português",
        "ไทย",
        "Tiếng Việt",
        "Bahasa Indonesia",
        "हिन्दी",
        "Türkçe",
        "Nederlands",
        "Polski"
      ]
    },
    {
      "identifier": "sourceLang",
      "label": "源语言 Source Language",
      "type": "multiple",
      "default": "auto",
      "values": ["auto", "zh-CN", "zh-TW", "en", "ja", "ko", "fr", "de", "es", "ru", "ar", "it", "pt", "th", "vi", "id", "hi", "tr", "nl", "pl"],
      "valueLabels": [
        "自动检测 Auto Detect",
        "中文（简体）",
        "中文（繁體）",
        "English",
        "日本語",
        "한국어",
        "Français",
        "Deutsch",
        "Español",
        "Русский",
        "العربية",
        "Italiano",
        "Português",
        "ไทย",
        "Tiếng Việt",
        "Bahasa Indonesia",
        "हिन्दी",
        "Türkçe",
        "Nederlands",
        "Polski"
      ]
    },
    {
      "identifier": "engine",
      "label": "引擎 Provider",
      "type": "multiple",
      "default": "google",
      "values": ["google", "microsoft", "openai", "anthropic", "kimi", "glm", "minimax", "deepseek"],
      "valueLabels": [
        "Google（免费，无需 Key）",
        "Microsoft（免费，无需 Key）",
        "OpenAI GPT",
        "Anthropic Claude（via OpenRouter）",
        "Kimi 月之暗面",
        "GLM 智谱 BigModel",
        "MiniMax 大模型",
        "DeepSeek 深度求索"
      ]
    },
    {
      "identifier": "apiKey",
      "label": "API Key（OpenAI/Anthropic/Kimi/GLM/MiniMax/DeepSeek 需要）",
      "type": "string",
      "default": ""
    },
    {
      "identifier": "model",
      "label": "模型 Model（留空用 provider 默认）",
      "type": "string",
      "default": ""
    },
    {
      "identifier": "region",
      "label": "Region（仅 MiniMax 有国内/海外两个 endpoint）",
      "type": "multiple",
      "default": "auto",
      "values": ["auto", "cn", "overseas"],
      "valueLabels": [
        "Auto（按系统 locale 自动判断）",
        "China 国内",
        "Overseas 海外"
      ]
    }
  ]
}

